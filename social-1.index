<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>The Culture Map — Chat (Final)</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap');
:root{
  --green:#1F8A5F;
  --green-light:#DFF4EA;
  --blue:#1F6FA8;
  --blue-light:#E3F1FB;
  --deep:#15384B;
  --ink:#284854;
  --soft:#F7FBFD;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100%;background:#edf3f5;display:grid;place-items:center;font-family:Inter,Arial,sans-serif}
.wrap{display:flex;flex-direction:column;align-items:center;gap:14px}
#stage{position:relative;width:min(92vw,560px);aspect-ratio:1/1;overflow:hidden;border-radius:24px;background:linear-gradient(180deg,#f9fdff 0%,#eef9f4 100%);box-shadow:0 24px 60px rgba(24,55,70,.16)}
.slide{position:absolute;inset:0;display:none;align-items:center;justify-content:center;padding:9% 9% 11%;overflow:hidden}.slide.active{display:flex}
.inner{position:relative;z-index:3;width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}
.brand{position:absolute;top:5%;left:50%;transform:translateX(-50%);z-index:8;opacity:0;animation:logoIn .6s .1s ease forwards}
.brand img{height:clamp(19px,4vw,25px);width:auto;display:block}
.eyebrow{font:800 clamp(11px,2.2vw,13px)/1 Inter,sans-serif;letter-spacing:.18em;text-transform:uppercase;color:var(--blue);margin-bottom:14px}
.headline{font:700 clamp(26px,6vw,38px)/1.1 Space Grotesk,sans-serif;letter-spacing:-.03em;color:var(--deep);max-width:430px}
.headline .highlight{display:inline-block;background:var(--green-light);color:var(--green);padding:.05em .25em;border-radius:.28em}
.sub{margin-top:14px;font-size:clamp(14px,3vw,17px);line-height:1.42;color:var(--ink);font-weight:600;max-width:420px}
.intro .headline{animation:popIn .8s both}.intro .sub{animation:fadeUp .75s .25s both}

.chat-slide .inner{gap:10px;align-items:stretch}
.bubble-row{display:flex;width:100%;max-width:400px}
.bubble-row.them{justify-content:flex-start}
.bubble-row.us{justify-content:flex-end}
.bubble{max-width:82%;padding:11px 15px;border-radius:18px;font-size:clamp(12px,2.6vw,15px);font-weight:600;line-height:1.32;text-align:left;opacity:0;transform:translateY(10px);animation:itemIn .45s ease forwards}
.them .bubble{background:#eceff1;color:#5a6a70;border-bottom-left-radius:6px}
.us .bubble{background:var(--green-light);color:var(--green);border-bottom-right-radius:6px;font-weight:800}
.bubble-row:nth-child(1) .bubble{animation-delay:.2s}
.bubble-row:nth-child(2) .bubble{animation-delay:1.1s}

.end{background:linear-gradient(150deg,var(--blue),var(--green));color:#fff}.end .brand{filter:brightness(0) invert(1)}
.end .headline{color:#fff;font-size:clamp(22px,5vw,31px);max-width:450px;font-weight:600}.end .sub{color:rgba(255,255,255,.9);max-width:430px}
.end .headline,.end .sub{animation:fadeUp .8s both}.end .sub{animation-delay:.25s}
.tags{margin-top:14px;display:flex;flex-wrap:wrap;gap:6px;justify-content:center;max-width:400px}
.tag{font-size:clamp(10px,2vw,12px);font-weight:700;color:#fff;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.35);padding:4px 10px;border-radius:999px}

.progress{position:absolute;left:8%;right:8%;bottom:3.5%;height:8px;border-radius:999px;background:rgba(31,111,168,.12);overflow:hidden;z-index:7}.progress span{display:block;height:100%;width:0;border-radius:inherit;background:linear-gradient(90deg,var(--blue),var(--green));animation:progress var(--dur,4.5s) linear forwards}
.end .progress{background:rgba(255,255,255,.25)}.end .progress span{background:#fff}
#controls{display:flex;gap:10px;align-items:center;color:#5b7280;font-size:13px}button{border:1px solid rgba(23,56,75,.16);background:#fff;color:var(--deep);border-radius:999px;padding:7px 14px;cursor:pointer}
@keyframes popIn{from{opacity:0;transform:scale(.78)}to{opacity:1;transform:scale(1)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
@keyframes itemIn{to{opacity:1;transform:translateY(0)}}
@keyframes logoIn{from{opacity:0;transform:translate(-50%,-6px)}to{opacity:1;transform:translate(-50%,0)}}
@keyframes progress{from{width:0}to{width:100%}}
</style>
</head>
<body>
<div class="wrap">
  <div id="stage">
    <div class="brand"><img src="data:image/webp;base64," alt="Pathwayz logo"></div>

    <section class="slide intro active" data-duration="4600">
      <div class="inner">
        <div class="eyebrow">Book We Return To</div>
        <div class="headline">The Culture Map by Erin Meyer <span class="highlight">has been foundational</span></div>
        <div class="sub">to our work with global tech teams.</div>
      </div>
      <div class="progress" style="--dur:4.6s"><span></span></div>
    </section>

    <section class="slide chat-slide" data-duration="5600">
      <div class="inner">
        <div class="eyebrow">Easily Misread</div>
        <div class="bubble-row them"><div class="bubble">"That felt like an attitude problem."</div></div>
        <div class="bubble-row us"><div class="bubble">Personality, attitude, or performance issues.</div></div>
      </div>
      <div class="progress" style="--dur:5.6s"><span></span></div>
    </section>

    <section class="slide intro" data-duration="6400">
      <div class="inner">
        <div class="eyebrow">The Culture Map Shows</div>
        <div class="headline">Starting from a place of <span class="highlight">curiosity</span> can help leaders better understand these differences, reduce friction, and build trust.</div>
      </div>
      <div class="progress" style="--dur:6.4s"><span></span></div>
    </section>

    <section class="slide end" data-duration="7200">
      <div class="inner">
        <div class="headline">What other resources/tools do you find helpful in understanding and collaborating within other cultures?</div>
        <div class="tags">
          <span class="tag">#GlobalLeadership</span>
          <span class="tag">#CrossCulturalLeadership</span>
          <span class="tag">#TheCultureMap</span>
          <span class="tag">#TeamDevelopment</span>
          <span class="tag">#LeadershipDevelopment</span>
        </div>
      </div>
      <div class="progress" style="--dur:7.2s"><span></span></div>
    </section>
  </div>
  <div id="controls"><button id="replay">Replay</button><span>Culture Map — Chat (Final)</span></div>
</div>
<script>
const stage=document.getElementById('stage');
const replay=document.getElementById('replay');
const original=stage.innerHTML;
let timers=[];
function clearTimers(){timers.forEach(clearTimeout);timers=[]}
function play(){
  clearTimers();
  stage.innerHTML=original;
  const slides=[...stage.querySelectorAll('.slide')];
  let elapsed=0;
  slides.forEach((slide,i)=>{
    const d=Number(slide.dataset.duration||4500);
    if(i===0)slide.classList.add('active');else slide.classList.remove('active');
    if(i>0)timers.push(setTimeout(()=>{
      slides.forEach(s=>s.classList.remove('active'));
      slide.classList.add('active');
    },elapsed));
    elapsed+=d;
  });
  timers.push(setTimeout(play,elapsed));
}
replay.addEventListener('click',play);play();
</script>
</body>
</html>
